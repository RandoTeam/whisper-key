@echo off
chcp 65001 > nul
echo ==========================================
echo 🚀 Начинаем автоматическую установку Whisper Key...
echo ==========================================
echo.
echo ⚠️ ВАЖНО: Убедитесь, что у вас установлены Python 3.10+ и Node.js!
echo Если они не установлены, закройте это окно, установите их и запустите файл снова.
echo.
echo [1/2] Установка Python библиотек (движок ИИ)...
pip install .
if %errorlevel% neq 0 (
    echo.
    echo ❌ ОШИБКА: Не удалось установить Python зависимости. 
    echo Убедитесь, что Python установлен и при установке была поставлена галочка "Add Python to PATH".
    pause
    exit /b
)

echo.
echo [2/2] Установка интерфейса (Electron.js)...
cd src\whisper_key\gui_electron
call npm install
if %errorlevel% neq 0 (
    echo.
    echo ❌ ОШИБКА: Не удалось установить графический интерфейс.
    echo Убедитесь, что программа Node.js установлена на вашем ПК.
    cd ..\..\..
    pause
    exit /b
)
cd ..\..\..

echo.
echo ==========================================
echo ✅ Установка УСПЕШНО завершена! 
echo Теперь вы можете запускать программу двойным кликом по файлу start.bat
echo ==========================================
pause
